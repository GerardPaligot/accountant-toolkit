{
  "name": "@gpaligot/accountant-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Validate and manage an accountant workspace's YAML files against bundled schemas.",
  "bin": { "accountant": "./dist/index.js" },
  "files": ["dist", "schemas", "meta-docs.yaml"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
